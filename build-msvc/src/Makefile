	cd C:\Users\gmast\Documents\GitHub\forgottenserver-master\build-msvc
	$(MAKE) $(MAKESILENT) -f src\CMakeFiles\tfslib.dir\build.make /nologo -$(MAKEFLAGS) src\CMakeFiles\tfslib.dir\Unity\unity_9_cxx.cxx.i
	cd C:\Users\gmast\Documents\GitHub\forgottenserver-master\build-msvc\src
.PHONY : Unity\unity_9_cxx.cxx.i

Unity\unity_9_cxx.s: Unity\unity_9_cxx.cxx.s
.PHONY : Unity\unity_9_cxx.s

